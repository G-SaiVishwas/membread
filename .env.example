# Membread Environment Variables

# Required
OPENAI_API_KEY=your-openai-api-key-here

# Database
DATABASE_URL=postgresql://membread:membread_password@localhost:5432/membread
DATABASE_POOL_MIN_SIZE=5
DATABASE_POOL_MAX_SIZE=20

# JWT Authentication
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256

# OpenAI Models
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_COMPRESSION_MODEL=gpt-4o-mini

# Performance
RESPONSE_TIMEOUT_MS=200
SLOW_OPERATION_THRESHOLD_MS=150
MAX_CONTEXT_TOKENS=2000

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_SECONDS=60
CIRCUIT_BREAKER_HALF_OPEN_ATTEMPTS=3

# Retry Logic
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=0.1
RETRY_MAX_DELAY_SECONDS=2.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# SQLite Fallback
SQLITE_FALLBACK_PATH=./fallback

# ── Graphiti / Temporal Knowledge Graph ──────────────────────────────
# Backend: "falkordb" (default), "neo4j", "kuzu", or "memory" (in-memory)
GRAPHITI_BACKEND=falkordb
GRAPHITI_URI=bolt://localhost:7687
ENABLE_TEMPORAL=true

# ── Local LLM (Ollama — fully-local, no paid API required) ──────────
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3
LOCAL_EMBEDDING_MODEL=nomic-embed-text
GRAPHITI_LLM_MODEL=gpt-4o-mini

# ── Auto-summarisation ───────────────────────────────────────────────
SUMMARISE_EVERY_N=100
